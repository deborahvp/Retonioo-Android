<?xml version="1.0" encoding="utf-8"?>
<!--
  Permite tráfico HTTP en claro SOLO hacia el host del backend de desarrollo.
  10.0.2.2 es como el emulador de Android ve el "localhost" de la PC anfitriona.
  Todo el resto del tráfico sigue exigiendo HTTPS.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
